# Pantheon — environment variables
# Copy this file to .env.local and fill in values.
# .env.local is gitignored; .env.example is committed as documentation.

# ── Supabase ────────────────────────────────────────────────────────────────
# Public URL + anon key (exposed to browser bundles via NEXT_PUBLIC_*).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only service role key. Used by lib/supabase/server.ts to bypass RLS.
# NEVER prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# ── Authentication ──────────────────────────────────────────────────────────
# Login password checked by /api/auth/login. Sets the pantheon_session=1 cookie
# on success. Single-user app — this is the only credential.
PANTHEON_PASSWORD=

# Shared secret required by the native app for the exempted API routes:
#   /api/claude/parse-meal
#   /api/claude/parse-workout
#   /api/claude/parse-workout-image
#   /api/claude/parse-recipe
#   /api/whisper/transcribe
#   /api/withings/sync
#   /api/food/barcode    (Step 6 — empty stub today)
#   /api/food/search     (Step 6 — empty stub today)
# Native client sends it via the `x-pantheon-native-secret` header.
# Generate with: openssl rand -hex 32
PANTHEON_NATIVE_SHARED_SECRET=

# ── Claude / Anthropic ──────────────────────────────────────────────────────
# Used by lib/claude/claude.ts and lib/claude/workout.ts for meal/workout parsing,
# scoring, daily plan, and coach endpoints.
ANTHROPIC_API_KEY=

# ── OpenAI (Whisper transcription only) ─────────────────────────────────────
# Used by /api/whisper/transcribe to proxy native audio → Whisper API → text.
# Native B5b.3 voice meal logging consumes this route.
OPENAI_API_KEY=

# ── Withings (Body+ scale OAuth) ────────────────────────────────────────────
# Registered at https://developer.withings.com. Used by:
#   /api/auth/withings            (authorize redirect)
#   /api/auth/withings/callback   (token exchange)
#   /api/withings/sync            (token refresh)
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=
