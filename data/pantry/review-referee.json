  ],
  "ask_luke_classes": [
    {
      "class": "brand_flavor_or_exact_product",
      "examples": ["REBBL flavor", "Yasso flavor", "Magic Spoon flavor", "Kashi exact cereal"],
      "why": "Luke may care about exact brand/flavor macros."
    },
    {
      "class": "recipe_or_composite",
      "examples": ["bolognese", "banh mi", "pho", "vermicelli bowl", "mango sticky rice"],
      "why": "Macros depend on recipe/portion."
    },
    {
      "class": "restaurant_default",
      "examples": ["Chipotle bowl", "McDonald's item not already saved"],
      "why": "Needs official/menu source or Luke-specific default."
    },
    {
      "class": "ambiguous_generic",
      "examples": ["tomato", "mushrooms", "granola", "chips", "coffee"],
      "why": "Requires default policy or existing-row alias routing."
    }
  ]
}
