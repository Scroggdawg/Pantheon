      "notes": "Cracklin Oat Bran is branded cereal; raw oat bran is an ingredient."
    },
    {
      "target_contains": "mint",
      "candidate_contains": "mint julep",
      "notes": "Mint is an herb; mint julep is a cocktail."
    },
    {
      "target_contains": "tom kha soup",
      "candidate_contains": "tom collins",
      "notes": "Thai soup vs cocktail."
    },
    {
