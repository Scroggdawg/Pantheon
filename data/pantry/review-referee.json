{
  "version": 1,
  "name": "Pantry Review Referee",
  "purpose": "Machine-readable identity calls for autonomous pantry review. These rules answer: if Luke says target_contains, is candidate_contains the same food identity?",
  "principles": [
    "Identity comes before macros.",
    "Already-covered duplicates should route to existing rows or aliases, not create new products.",
    "Obvious common-sense mismatches should become rejection memory without Luke review.",
    "Restaurant, branded, recipe, cocktail, supplement, and personal-preference rows stay review/source-gated unless an exact trusted source exists."
  ],
  "compatible_pairs": [
    {
      "target_contains": "almond milk unsweetened",
      "candidate_contains": "almond milk, unsweetened",
      "notes": "Identity-compatible; duplicate/alias problem if Pantheon already has a row."
    },
    {
      "target_contains": "balsamic vinegar",
      "candidate_contains": "vinegar, balsamic",
      "notes": "Same identity."
    },
    {
      "target_contains": "banana",
      "candidate_contains": "bananas",
      "notes": "Same identity."
    },
    {
      "target_contains": "cashews",
      "candidate_contains": "cashews",
      "notes": "Same identity, NFS acceptable as generic cashew."
    },
    {
      "target_contains": "apple cider vinegar",
      "candidate_contains": "vinegar, cider",
      "notes": "USDA wording for cider vinegar; macros effectively irrelevant."
    },
    {
      "target_contains": "cilantro",
      "candidate_contains": "coriander (cilantro) leaves",
      "notes": "Fresh coriander leaves are cilantro. Coriander seed/dried coriander would be a different row."
    },
    {
      "target_contains": "italian sausage cooked",
      "candidate_contains": "sausage, italian",
      "notes": "Compatible generic sausage identity; still keep as covered/source-gated if duplicate."
    },
    {
      "target_contains": "bbq ribs",
      "candidate_contains": "beef, rib, back ribs",
      "notes": "Compatible ingredient direction, but BBQ/ribs serving remains source-gated."
    },
    {
      "target_contains": "jalapeno",
      "candidate_contains": "peppers, jalapeno",
      "notes": "Same identity."
    },
    {
      "target_contains": "oregano",
      "candidate_contains": "spices, oregano",
      "notes": "Compatible if Luke means dried oregano; fresh oregano should be separate."
    },
    {
      "target_contains": "sriracha",
      "candidate_contains": "sauce, hot chile, sriracha",
      "notes": "Same sauce identity; brand-specific sriracha may be separate later."
    }
  ],
  "mismatch_pairs": [
    {
      "target_contains": "apple",
      "candidate_contains": "fruit butters",
      "notes": "Apple is a fruit; apple butter is a jarred spread."
    },
    {
      "target_contains": "bean sprouts",
